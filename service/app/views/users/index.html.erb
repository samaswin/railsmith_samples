<main style="max-width: 900px; margin: 48px auto; padding: 0 16px;">
  <header style="display:flex; align-items: baseline; justify-content: space-between; gap: 16px;">
    <h1 style="margin: 0;">Users</h1>
    <%= link_to "New user", new_user_path, style: "text-decoration:none; padding:10px 12px; border-radius:10px; border:1px solid #ddd; background:#fff;" %>
  </header>

  <section style="margin-top: 20px;">
    <% if @users.any? %>
      <ul style="list-style:none; padding:0; margin:0; display:grid; gap:10px;">
        <% @users.each do |user| %>
          <li style="border:1px solid #eee; border-radius:12px; padding:14px 16px; background:#fff;">
            <div style="display:flex; align-items:center; justify-content:space-between; gap: 16px;">
              <div>
                <div style="font-weight:600;">
                  <%= link_to(user.name.presence || user.email, user_path(user), style: "color:inherit; text-decoration:none;") %>
                </div>
                <div style="color:#666; font-size: 13px; margin-top: 4px;"><%= user.email %></div>
              </div>
              <div style="display:flex; align-items:center; gap: 10px;">
                <%= link_to "Edit", edit_user_path(user), style: "text-decoration:none; color:#111827; font-size: 13px;" %>
                <%= button_to "Delete", user_path(user), method: :delete, form: { data: { turbo_confirm: "Delete this user?" } }, style: "cursor:pointer; padding:6px 10px; border-radius:10px; border:1px solid #ddd; background:#fff; color:#111827; font-size: 13px;" %>
                <div style="color:#999; font-size: 13px;">#<%= user.id %></div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div style="margin-top: 18px; padding: 18px 16px; border: 1px dashed #ddd; border-radius: 12px; background: #fafafa;">
        <div style="font-weight:600;">No users yet</div>
        <div style="color:#666; margin-top:6px;">Create your first one to get started.</div>
      </div>
    <% end %>
  </section>
</main>

